{
  "openapi": "3.1.0",
  "info": {
    "title": "Team arbeidsforhold statistikk api",
    "description": "Team arbeidsforhold statistikk api",
    "version": "1.0.0"
  },
  "tags": [
    {
      "name": "repo",
      "description": "Api for repoer"
    },
    {
      "name": "me",
      "description": "Api for info om innlogget bruker"
    }
  ],
  "servers": [
    {
      "url": "/"
    }
  ],
  "paths": {
    "/api/repo": {
      "get": {
        "tags": ["repo"],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Repo"
                  }
                }
              }
            },
            "description": "Liste over teamet's repoer"
          }
        }
      }
    },
    "/api/repo/{repoName}": {
      "get": {
        "tags": ["repo"],
        "parameters": [
          {
            "in": "path",
            "name": "repoName",
            "schema": {
              "type": "string"
            },
            "required": true,
            "description": "Navnet på repoet, slik som det er i url'er, dvs neste path-element etter /navikt/ på github"
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RepoDetails"
                }
              }
            },
            "description": "Detaljer for ett repo"
          }
        }
      }
    },
    "/api/me": {
      "get": {
        "tags": ["me"],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            },
            "description": "Den innloggede brukeren"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Repo": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "errorCount": {
            "type": "integer"
          },
          "criticalCount": {
            "type": "integer"
          }
        },
        "required": [
          "name",
          "url",
          "errorCount",
          "criticalCount"
        ]
      },
      "RepoDetails": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Repo"
          },
          {
            "type": "object",
            "properties": {
              "deploymentNames": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "environments": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "deploymentConsistent": {
                "type": "boolean"
              },
              "errors": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "required": [
              "deploymentNames",
              "environments",
              "deploymentConsistent"
            ]
          }
        ]
      },
      "User": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "debug": {
            "type": "string"
          }
        },
        "required": [
          "name"
        ]
      }
    }
  }
}
