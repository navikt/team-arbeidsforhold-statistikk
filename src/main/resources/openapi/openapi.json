{
  "openapi": "3.1.0",
  "info": {
    "title": "Team arbeidsforhold statistikk api",
    "description": "Team arbeidsforhold statistikk api",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/api"
    }
  ],
  "paths": {
    "/repo": {
      "get": {
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Repo"
                  }
                }
              }
            },
            "description": "Liste over teamet's repoer"
          }
        }
      }
    },
    "/repo/{repoName}": {
      "get": {
        "parameters": [
          {
            "in": "path",
            "name": "repoName",
            "schema": {
              "type": "string"
            },
            "required": true,
            "description": "Navnet på repoet, slik som det er i url'er, dvs neste path-element etter /navikt/ på github"
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                    "$ref": "#/components/schemas/RepoDetails"
                }
              }
            },
            "description": "Detaljer for ett repo"
          }
        }
      }
    },
    "/me": {
      "get": {
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            },
            "description": "Den innloggede brukeren"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Repo": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "errorCount": {
            "type": "integer"
          },
          "criticalCount": {
            "type": "integer"
          }
        },
        "required": [
          "name",
          "url",
          "errorcount",
          "criticalCount"
        ]
      },
      "RepoDetails": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "errors": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "deploymentNames": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "environments": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "deploymentConsistent": {
            "type": "boolean"
          }
        },
        "required": [
          "name",
          "url",
          "errors",
          "deploymentNames",
          "environments",
          "deploymentConsistent"
        ]
      },
      "User": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "debug": {
            "type": "string"
          }
        },
        "required": [
          "name"
        ]
      }
    }
  }
}
